<Window x:Class="RamDump.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:RamDump.Converters"
        xmlns:vm="clr-namespace:RamDump.ViewModels"
        xmlns:views="clr-namespace:RamDump.Views"
        Title="RAM Dump" Width="900" Height="700"
        MinWidth="700" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Icon="/Resources/app.ico"
        Background="{StaticResource BgBaseBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI" FontSize="13">

    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}"/>
        <KeyBinding Modifiers="Ctrl" Key="T" Command="{Binding TrimAllCommand}"/>
        <KeyBinding Modifiers="Ctrl" Key="F" Command="{Binding FocusSearchCommand}"/>
        <KeyBinding Modifiers="Ctrl" Key="E" Command="{Binding ExportCsvCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <conv:BytesToReadableConverter x:Key="BytesToReadable"/>
        <conv:BytesToGigabytesConverter x:Key="BytesToGb"/>
        <conv:PercentToColorConverter x:Key="PercentToColor"/>
        <conv:InvertBoolToVisibilityConverter x:Key="InvertBoolToVisibility"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:GroupSumConverter x:Key="GroupSum"/>

        <!-- Destructive Button (Voll-Bereinigung) -->
        <Style x:Key="DestructiveButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
        </Style>

    </Window.Resources>

    <TabControl x:Name="MainTabs" SelectionChanged="MainTabs_SelectionChanged">
        <TabItem Header="RAM">
        <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Admin-Warnung -->
        <Border Grid.Row="0" CornerRadius="6" Padding="10,8" Margin="0,0,0,12"
                BorderBrush="{StaticResource WarningBrush}" BorderThickness="1"
                Visibility="{Binding IsAdmin, Converter={StaticResource InvertBoolToVisibility}}">
            <Border.Background>
                <SolidColorBrush Color="{StaticResource WarningColor}" Opacity="0.12"/>
            </Border.Background>
            <TextBlock Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap">
                <Run FontWeight="Bold" Text="Keine Admin-Rechte"/>
                <Run Text=" — RAM-Analyse funktioniert, Bereinigung ist deaktiviert. Als Administrator starten für volle Funktionalität."/>
            </TextBlock>
        </Border>

        <!-- Dashboard Karten -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- RAM Nutzung -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="RAM NUTZUNG" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock FontSize="28" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Text="{Binding SystemMemory.UsedPhysical, Converter={StaticResource BytesToGb}}"/>
                        <TextBlock FontSize="14" VerticalAlignment="Bottom" Margin="4,0,0,5"
                                   Foreground="{StaticResource TextTertiaryBrush}">
                            <Run Text="/"/>
                            <Run Text="{Binding SystemMemory.TotalPhysical, Converter={StaticResource BytesToGb}, Mode=OneWay}"/>
                            <Run Text="GB"/>
                        </TextBlock>
                    </StackPanel>
                    <ProgressBar Value="{Binding SystemMemory.UsagePercent, Mode=OneWay}"
                                 Maximum="100"
                                 Foreground="{Binding SystemMemory.UsagePercent, Converter={StaticResource PercentToColor}}"/>
                    <TextBlock HorizontalAlignment="Right" Margin="0,6,0,0" FontSize="11"
                               Foreground="{StaticResource TextTertiaryBrush}"
                               Text="{Binding SystemMemory.UsagePercent, StringFormat={}{0:F1}%}"/>
                </StackPanel>
            </Border>

            <!-- Frei -->
            <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="VERFÜGBAR" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="28" FontWeight="SemiBold"
                                   Foreground="{StaticResource LoadOkBrush}"
                                   Text="{Binding SystemMemory.AvailablePhysical, Converter={StaticResource BytesToGb}}"/>
                        <TextBlock FontSize="14" VerticalAlignment="Bottom" Margin="4,0,0,5"
                                   Foreground="{StaticResource TextTertiaryBrush}" Text="GB"/>
                    </StackPanel>
                    <TextBlock Margin="0,8,0,0" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                               Text="{Binding SystemMemory.AvailablePhysical, Converter={StaticResource BytesToReadable}}"/>
                </StackPanel>
            </Border>

            <!-- Cache -->
            <Border Grid.Column="4" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="CACHE" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="28" FontWeight="SemiBold"
                                   Foreground="{StaticResource InfoBrush}"
                                   Text="{Binding SystemMemory.CachedBytes, Converter={StaticResource BytesToGb}}"/>
                        <TextBlock FontSize="14" VerticalAlignment="Bottom" Margin="4,0,0,5"
                                   Foreground="{StaticResource TextTertiaryBrush}" Text="GB"/>
                    </StackPanel>
                    <TextBlock Margin="0,8,0,0" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                               Text="{Binding SystemMemory.CachedBytes, Converter={StaticResource BytesToReadable}}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Aktions-Buttons (COLORS.md §9) -->
        <WrapPanel Grid.Row="2" Margin="0,0,0,8">
            <Button Content="Alles Trimmen (Ctrl+T)" Command="{Binding TrimAllCommand}" Margin="0,0,8,4"/>
            <Button Content="Standby Leeren" Command="{Binding ClearStandbyCommand}" Margin="0,0,8,4"/>
            <Button Content="Voll-Bereinigung" Command="{Binding FullCleanupCommand}"
                    Style="{StaticResource DestructiveButton}" Margin="0,0,16,4"/>
            <Button Content="Aktualisieren (F5)" Command="{Binding RefreshCommand}" Margin="0,0,8,4"/>
            <Button Content="Export CSV (Ctrl+E)" Command="{Binding ExportCsvCommand}" Margin="0,0,8,4"/>
        </WrapPanel>

        <!-- Status + Suche -->
        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" VerticalAlignment="Center"
                       Foreground="{StaticResource TextTertiaryBrush}"
                       Text="{Binding StatusText}"/>

            <ToggleButton Grid.Column="1" Content="Gruppieren"
                          IsChecked="{Binding IsGrouped}" Margin="0,0,8,0"/>

            <ToggleButton Grid.Column="2" Content="Win-Prozesse"
                          IsChecked="{Binding ShowSystemProcesses}" Margin="0,0,8,0"/>

            <ToggleButton Grid.Column="3" Content="Auto-Refresh"
                          IsChecked="{Binding AutoRefresh}" Margin="0,0,8,0"/>

            <Grid Grid.Column="4">
                <TextBox x:Name="SearchBox"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center"/>
                <TextBlock Text="Suche... (Ctrl+F)" IsHitTestVisible="False"
                           VerticalAlignment="Center" Margin="8,0,0,0"
                           Foreground="{StaticResource TextTertiaryBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Grid>

        <!-- Prozessliste -->
        <DataGrid Grid.Row="4"
                  ItemsSource="{Binding ProcessesView}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  SelectionMode="Single"
                  BorderThickness="0"
                  RowHeaderWidth="0"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  EnableRowVirtualization="True">

            <DataGrid.Template>
                <ControlTemplate TargetType="DataGrid">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ScrollViewer x:Name="DG_ScrollViewer" Focusable="False">
                            <ScrollViewer.Template>
                                <ControlTemplate TargetType="ScrollViewer">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <DataGridColumnHeadersPresenter x:Name="PART_ColumnHeadersPresenter"
                                            Grid.Column="0" Grid.Row="0"
                                            Visibility="{Binding HeadersVisibility, ConverterParameter={x:Static DataGridHeadersVisibility.Column}, Converter={x:Static DataGrid.HeadersVisibilityConverter}, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>

                                        <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                            Grid.Column="0" Grid.Row="1"
                                            CanContentScroll="{TemplateBinding CanContentScroll}"/>

                                        <!-- Vertical ScrollBar (dark) -->
                                        <ScrollBar x:Name="PART_VerticalScrollBar"
                                            Grid.Column="1" Grid.Row="0" Grid.RowSpan="2"
                                            Orientation="Vertical" Width="10"
                                            Maximum="{TemplateBinding ScrollableHeight}"
                                            ViewportSize="{TemplateBinding ViewportHeight}"
                                            Value="{Binding VerticalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}"
                                            Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}">
                                            <ScrollBar.Template>
                                                <ControlTemplate TargetType="ScrollBar">
                                                    <Border Background="{StaticResource BgSurfaceBrush}">
                                                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                                                            <Track.DecreaseRepeatButton>
                                                                <RepeatButton Command="ScrollBar.PageUpCommand"
                                                                    OverridesDefaultStyle="True" Focusable="False">
                                                                    <RepeatButton.Template>
                                                                        <ControlTemplate><Border Background="Transparent"/></ControlTemplate>
                                                                    </RepeatButton.Template>
                                                                </RepeatButton>
                                                            </Track.DecreaseRepeatButton>
                                                            <Track.Thumb>
                                                                <Thumb OverridesDefaultStyle="True" Margin="2">
                                                                    <Thumb.Template>
                                                                        <ControlTemplate TargetType="Thumb">
                                                                            <Border x:Name="tb" CornerRadius="4"
                                                                                    Background="{StaticResource BorderDefaultBrush}"/>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter TargetName="tb" Property="Background"
                                                                                            Value="{StaticResource BorderStrongBrush}"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Thumb.Template>
                                                                </Thumb>
                                                            </Track.Thumb>
                                                            <Track.IncreaseRepeatButton>
                                                                <RepeatButton Command="ScrollBar.PageDownCommand"
                                                                    OverridesDefaultStyle="True" Focusable="False">
                                                                    <RepeatButton.Template>
                                                                        <ControlTemplate><Border Background="Transparent"/></ControlTemplate>
                                                                    </RepeatButton.Template>
                                                                </RepeatButton>
                                                            </Track.IncreaseRepeatButton>
                                                        </Track>
                                                    </Border>
                                                </ControlTemplate>
                                            </ScrollBar.Template>
                                        </ScrollBar>

                                        <!-- Horizontal ScrollBar (dark) -->
                                        <ScrollBar x:Name="PART_HorizontalScrollBar"
                                            Grid.Column="0" Grid.Row="2"
                                            Orientation="Horizontal" Height="10"
                                            Maximum="{TemplateBinding ScrollableWidth}"
                                            ViewportSize="{TemplateBinding ViewportWidth}"
                                            Value="{Binding HorizontalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}"
                                            Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}">
                                            <ScrollBar.Template>
                                                <ControlTemplate TargetType="ScrollBar">
                                                    <Border Background="{StaticResource BgSurfaceBrush}">
                                                        <Track x:Name="PART_Track" IsDirectionReversed="False">
                                                            <Track.DecreaseRepeatButton>
                                                                <RepeatButton Command="ScrollBar.PageLeftCommand"
                                                                    OverridesDefaultStyle="True" Focusable="False">
                                                                    <RepeatButton.Template>
                                                                        <ControlTemplate><Border Background="Transparent"/></ControlTemplate>
                                                                    </RepeatButton.Template>
                                                                </RepeatButton>
                                                            </Track.DecreaseRepeatButton>
                                                            <Track.Thumb>
                                                                <Thumb OverridesDefaultStyle="True" Margin="2">
                                                                    <Thumb.Template>
                                                                        <ControlTemplate TargetType="Thumb">
                                                                            <Border x:Name="tb" CornerRadius="4"
                                                                                    Background="{StaticResource BorderDefaultBrush}"/>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter TargetName="tb" Property="Background"
                                                                                            Value="{StaticResource BorderStrongBrush}"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Thumb.Template>
                                                                </Thumb>
                                                            </Track.Thumb>
                                                            <Track.IncreaseRepeatButton>
                                                                <RepeatButton Command="ScrollBar.PageRightCommand"
                                                                    OverridesDefaultStyle="True" Focusable="False">
                                                                    <RepeatButton.Template>
                                                                        <ControlTemplate><Border Background="Transparent"/></ControlTemplate>
                                                                    </RepeatButton.Template>
                                                                </RepeatButton>
                                                            </Track.IncreaseRepeatButton>
                                                        </Track>
                                                    </Border>
                                                </ControlTemplate>
                                            </ScrollBar.Template>
                                        </ScrollBar>
                                    </Grid>
                                </ControlTemplate>
                            </ScrollViewer.Template>
                            <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </DataGrid.Template>

            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Diesen Prozess trimmen"
                              Command="{Binding TrimProcessCommand}"
                              CommandParameter="{Binding ProcessesView/}"/>
                </ContextMenu>
            </DataGrid.ContextMenu>

            <DataGrid.GroupStyle>
                <GroupStyle>
                    <GroupStyle.ContainerStyle>
                        <Style TargetType="{x:Type GroupItem}">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type GroupItem}">
                                        <StackPanel>
                                            <ToggleButton x:Name="ExpandToggle" IsChecked="False"
                                                          OverridesDefaultStyle="True" Focusable="False">
                                                <ToggleButton.Template>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border Background="{StaticResource BgRaisedBrush}"
                                                                CornerRadius="3" Padding="8,4" Margin="0,2"
                                                                Cursor="Hand">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Image Source="{Binding Items[0].Icon}" Width="16" Height="16"
                                                                       Margin="0,0,6,0" Opacity="0.85"
                                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                                       VerticalAlignment="Center"/>
                                                                <TextBlock x:Name="Arrow" Text="▶" FontSize="9"
                                                                           Foreground="{StaticResource TextTertiaryBrush}"
                                                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                                <TextBlock Foreground="{StaticResource TextTertiaryBrush}" Margin="8,0,0,0">
                                                                    <TextBlock.Text>
                                                                        <MultiBinding StringFormat="({0} — {1})">
                                                                            <Binding Path="ItemCount"/>
                                                                            <Binding Path="Items" Converter="{StaticResource GroupSum}" ConverterParameter="WorkingSet"/>
                                                                        </MultiBinding>
                                                                    </TextBlock.Text>
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter TargetName="Arrow" Property="Text" Value="▼"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </ToggleButton.Template>
                                            </ToggleButton>
                                            <ItemsPresenter x:Name="ItemsHost"
                                                            Visibility="{Binding IsChecked, ElementName=ExpandToggle, Converter={StaticResource BoolToVisibility}}"/>
                                        </StackPanel>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </GroupStyle.ContainerStyle>
                </GroupStyle>
            </DataGrid.GroupStyle>

            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Name" Width="*" MinWidth="200" SortMemberPath="Name">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Image Source="{Binding Icon}" Width="16" Height="16" Margin="0,0,6,0"
                                       Opacity="0.85"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock Text="▲" Margin="0,0,4,0"
                                           Foreground="{StaticResource WarningBrush}"
                                           Visibility="{Binding IsGrowing, Converter={StaticResource BoolToVisibility}}"/>
                                <TextBlock Text="{Binding Name}" FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="PID" Binding="{Binding Pid}" Width="90">
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                            <Setter Property="HorizontalContentAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                            <Setter Property="TextAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Working Set" Width="140"
                                    Binding="{Binding WorkingSet, Converter={StaticResource BytesToReadable}}"
                                    SortMemberPath="WorkingSet">
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                            <Setter Property="HorizontalContentAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            <Setter Property="TextAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Private" Width="140"
                                    Binding="{Binding PrivateBytes, Converter={StaticResource BytesToReadable}}"
                                    SortMemberPath="PrivateBytes">
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                            <Setter Property="HorizontalContentAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                            <Setter Property="TextAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Peak" Width="140"
                                    Binding="{Binding PeakWorkingSet, Converter={StaticResource BytesToReadable}}"
                                    SortMemberPath="PeakWorkingSet">
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                            <Setter Property="HorizontalContentAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                            <Setter Property="TextAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
        </TabItem>

        <TabItem Header="Monitor">
            <views:MonitorView DataContext="{Binding Monitor}"/>
        </TabItem>

        <TabItem Header="About">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel MaxWidth="520" HorizontalAlignment="Center"
                            Margin="32,32,32,32" DataContext="{Binding About}">

                    <!-- Header: Icon + Titel -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <Image Source="/Resources/app.ico" Width="64" Height="64" Margin="0,0,20,0"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock FontSize="24" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}">
                                <Run Text="RAM Dump"/>
                                <Run Text=" v" Foreground="{StaticResource TextTertiaryBrush}"/>
                                <Run Text="{Binding AppVersion, Mode=OneTime}"
                                     Foreground="{StaticResource TextTertiaryBrush}"/>
                            </TextBlock>
                            <TextBlock Text="Windows RAM-Manager &amp; System-Monitor"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Divider -->
                    <Border Height="1" Background="{StaticResource BorderSubtleBrush}" Margin="0,0,0,20"/>

                    <!-- Entwickler -->
                    <TextBlock Text="ENTWICKLER" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10"/>
                    <TextBlock Text="Nawinn Gutzeit" FontSize="14"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBlock Margin="0,0,0,6">
                        <Hyperlink NavigateUri="https://stackschmiede.de"
                                   RequestNavigate="Hyperlink_RequestNavigate"
                                   Foreground="{StaticResource AccentBrush}">
                            stackschmiede.de
                        </Hyperlink>
                    </TextBlock>
                    <TextBlock Margin="0,0,0,24">
                        <Hyperlink NavigateUri="https://github.com/stackschmiede/stack-ramdump"
                                   RequestNavigate="Hyperlink_RequestNavigate"
                                   Foreground="{StaticResource AccentBrush}">
                            github.com/stackschmiede/stack-ramdump
                        </Hyperlink>
                    </TextBlock>

                    <!-- System-Infos -->
                    <TextBlock Text="SYSTEM" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="CPU"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{Binding CpuName}"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"
                                   TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="GPU"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding GpuName}"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"
                                   TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="RAM"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="{Binding RamTotal}"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="OS"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="3" Grid.Column="1"
                                   Text="{Binding OsDescription}"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"
                                   TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Uptime"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Row="4" Grid.Column="1"
                                   Text="{Binding Uptime}"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </Grid>

                    <!-- Dependencies -->
                    <TextBlock Text="ABHÄNGIGKEITEN" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10"/>
                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" LineHeight="22"
                               Margin="0,0,0,24">
                        <Run Text="· .NET 8 · WPF"/><LineBreak/>
                        <Run Text="· CommunityToolkit.Mvvm 8.4.0"/><LineBreak/>
                        <Run Text="· Hardcodet.NotifyIcon.Wpf 2.0.1"/><LineBreak/>
                        <Run Text="· LibreHardwareMonitorLib 0.9.4"/>
                    </TextBlock>

                    <!-- Footer -->
