<UserControl x:Class="RamDump.Views.MonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:RamDump.Converters">

    <UserControl.Resources>
        <conv:PercentToColorConverter x:Key="PercentToColor"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:InvertBoolToVisibilityConverter x:Key="InvertBoolToVisibility"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Grid Grid.Row="0" Margin="16,10,16,8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ToggleButton Content="▋▋ Pause" IsChecked="{Binding IsPaused}" Margin="0,0,8,0"/>
                <ComboBox SelectedValue="{Binding RefreshIntervalSeconds}"
                          SelectedValuePath="Tag" Width="90">
                    <ComboBoxItem Content="1 Sek." Tag="1"/>
                    <ComboBoxItem Content="2 Sek." Tag="2"/>
                    <ComboBoxItem Content="5 Sek." Tag="5"/>
                    <ComboBoxItem Content="10 Sek." Tag="10"/>
                </ComboBox>
            </StackPanel>
            <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                       Foreground="{StaticResource TextTertiaryBrush}"
                       Text="{Binding LastUpdateTime, StringFormat='Letzter Update: {0}'}"/>
        </Grid>

        <!-- Banner: LHM nicht verfügbar -->
        <Border Grid.Row="1" Margin="16,0,16,8" CornerRadius="6" Padding="10,8"
                BorderBrush="{StaticResource WarningBrush}" BorderThickness="1"
                Visibility="{Binding HardwareAvailable, Converter={StaticResource InvertBoolToVisibility}}">
            <Border.Background>
                <SolidColorBrush Color="{StaticResource WarningColor}" Opacity="0.10"/>
            </Border.Background>
            <TextBlock Foreground="{StaticResource TextPrimaryBrush}">
                <Run FontWeight="Bold" Text="Hardware-Sensoren nicht verfügbar."/>
                <Run Text=" LibreHardwareMonitor konnte nicht initialisiert werden. Nur CPU-Auslastung via Fallback."/>
            </TextBlock>
        </Border>

        <!-- 2×2 Sensor-Karten -->
        <Grid Grid.Row="2" Margin="16,0,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- CPU -->
            <Border Grid.Column="0" Grid.Row="0" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="CPU" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>

                    <TextBlock FontSize="28" FontWeight="SemiBold" Margin="0,0,0,10"
                               Foreground="{Binding CpuUsage, Converter={StaticResource PercentToColor}}"
                               Text="{Binding CpuUsage, StringFormat={}{0:F1}%, TargetNullValue='—'}"/>

                    <!-- Per-Core Balken: rotierter ProgressBar (horizontal → vertikal) -->
                    <ItemsControl ItemsSource="{Binding Cores}" Margin="0,0,0,10">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ProgressBar Width="36" Height="14" Margin="0,0,3,3"
                                             Value="{Binding Percent}" Maximum="100"
                                             Foreground="{Binding Percent, Converter={StaticResource PercentToColor}}"
                                             ToolTip="{Binding Percent, StringFormat=Core {}{0:F0}%}">
                                    <ProgressBar.LayoutTransform>
                                        <RotateTransform Angle="-90"/>
                                    </ProgressBar.LayoutTransform>
                                </ProgressBar>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                            <Run Text="Temp: "/>
                            <Run Text="{Binding CpuTemp, StringFormat={}{0:F0}°C, TargetNullValue='—'}"
                                 Foreground="{Binding CpuTemp, Converter={StaticResource PercentToColor}}"/>
                        </TextBlock>
                        <TextBlock Grid.Column="1" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Right">
                            <Run Text="{Binding CpuFreqMHz, StringFormat={}{0:F0} MHz, TargetNullValue='—'}"/>
                        </TextBlock>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- GPU -->
            <Border Grid.Column="2" Grid.Row="0" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="GPU" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>

                    <TextBlock FontSize="28" FontWeight="SemiBold" Margin="0,0,0,12"
                               Foreground="{Binding GpuUsage, Converter={StaticResource PercentToColor}}"
                               Text="{Binding GpuUsage, StringFormat={}{0:F1}%, TargetNullValue='—'}"/>

                    <TextBlock FontSize="12" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}">
                        <Run Text="VRAM: "/>
                        <Run Foreground="{StaticResource TextPrimaryBrush}"
                             Text="{Binding GpuVramUsedGb, StringFormat={}{0:F1}, TargetNullValue='—'}"/>
                        <Run Text=" / "/>
                        <Run Text="{Binding GpuVramTotalGb, StringFormat={}{0:F1} GB, TargetNullValue='—'}"/>
                    </TextBlock>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                            <Run Text="Temp: "/>
                            <Run Text="{Binding GpuTemp, StringFormat={}{0:F0}°C, TargetNullValue='—'}"
                                 Foreground="{Binding GpuTemp, Converter={StaticResource PercentToColor}}"/>
                        </TextBlock>
                        <TextBlock Grid.Column="1" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Right">
                            <Run Text="{Binding GpuClockMHz, StringFormat={}{0:F0} MHz, TargetNullValue='—'}"/>
                        </TextBlock>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Disk -->
            <Border Grid.Column="0" Grid.Row="2" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="DISK" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>

                    <TextBlock FontSize="16" FontWeight="Medium" Margin="0,0,0,6">
                        <Run Foreground="{StaticResource InfoBrush}" Text="↓ "/>
                        <Run Foreground="{StaticResource TextPrimaryBrush}"
                             Text="{Binding DiskReadMBps, StringFormat={}{0:F1} MB/s, TargetNullValue='— MB/s'}"/>
                    </TextBlock>
                    <TextBlock FontSize="16" FontWeight="Medium" Margin="0,0,0,12">
                        <Run Foreground="{StaticResource WarningBrush}" Text="↑ "/>
                        <Run Foreground="{StaticResource TextPrimaryBrush}"
                             Text="{Binding DiskWriteMBps, StringFormat={}{0:F1} MB/s, TargetNullValue='— MB/s'}"/>
                    </TextBlock>

                    <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                        <Run Text="Temp: "/>
                        <Run Text="{Binding DiskTemp, StringFormat={}{0:F0}°C, TargetNullValue='—'}"
                             Foreground="{Binding DiskTemp, Converter={StaticResource PercentToColor}}"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Netzwerk -->
            <Border Grid.Column="2" Grid.Row="2" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="NETZWERK" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>

                    <TextBlock FontSize="16" FontWeight="Medium" Margin="0,0,0,6">
                        <Run Foreground="{StaticResource InfoBrush}" Text="↓ "/>
                        <Run Foreground="{StaticResource TextPrimaryBrush}"
                             Text="{Binding NetDownMbitps, StringFormat={}{0:F1} Mbit/s, TargetNullValue='— Mbit/s'}"/>
                    </TextBlock>
                    <TextBlock FontSize="16" FontWeight="Medium">
                        <Run Foreground="{StaticResource WarningBrush}" Text="↑ "/>
                        <Run Foreground="{StaticResource TextPrimaryBrush}"
                             Text="{Binding NetUpMbitps, StringFormat={}{0:F1} Mbit/s, TargetNullValue='— Mbit/s'}"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
