<UserControl x:Class="RamDump.Views.MonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:RamDump.Converters">

    <UserControl.Resources>
        <conv:PercentToColorConverter x:Key="PercentToColor"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:InvertBoolToVisibilityConverter x:Key="InvertBoolToVisibility"/>
        <conv:BytesToGigabytesConverter x:Key="BytesToGb"/>
        <conv:SparklinePointsConverter x:Key="Sparkline"/>

        <!-- Kleine KPI-Card (im Hero rechts) -->
        <Style x:Key="MiniStatBlock" TargetType="StackPanel">
            <Setter Property="Margin" Value="0,0,0,0"/>
        </Style>

        <!-- Sensor-Card Style -->
        <Style x:Key="SensorCard" TargetType="Border" BasedOn="{StaticResource CardBorder}">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="MinHeight" Value="180"/>
        </Style>

        <!-- Segment-Button (Toolbar) -->
        <Style x:Key="SegButton" TargetType="ToggleButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Padding="0" Background="{StaticResource BgBaseBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
            <RowDefinition Height="Auto"/>  <!-- LHM Banner -->
            <RowDefinition Height="Auto"/>  <!-- Hero RAM -->
            <RowDefinition Height="Auto"/>  <!-- 4-Card Grid -->
            <RowDefinition Height="Auto"/>  <!-- Ticker -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════ Toolbar ═══════════════════════════════════════ -->
        <Grid Grid.Row="0" Margin="20,14,20,8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Pause / Live Toggle -->
                <ToggleButton IsChecked="{Binding Monitor.IsPaused}" Padding="12,6" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource LoadOkBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Monitor.IsPaused}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource LoadHighBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="Text" Value="Live"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Monitor.IsPaused}" Value="True">
                                            <Setter Property="Text" Value="Pause"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </ToggleButton>

                <!-- Intervall -->
                <ComboBox SelectedValue="{Binding Monitor.RefreshIntervalSeconds}"
                          SelectedValuePath="Tag" Width="100">
                    <ComboBoxItem Content="1 Sek." Tag="1"/>
                    <ComboBoxItem Content="2 Sek." Tag="2"/>
                    <ComboBoxItem Content="5 Sek." Tag="5"/>
                    <ComboBoxItem Content="10 Sek." Tag="10"/>
                </ComboBox>
            </StackPanel>

            <!-- Last update -->
            <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                       Foreground="{StaticResource TextTertiaryBrush}" FontSize="12">
                <Run Text="Letzter Update · "/>
                <Run Foreground="{StaticResource TextSecondaryBrush}"
                     Text="{Binding Monitor.LastUpdateTime}"/>
            </TextBlock>
        </Grid>

        <!-- ═══════════════════════════════════════ LHM-Banner ═══════════════════════════════════ -->
        <Border Grid.Row="1" Margin="20,0,20,8" CornerRadius="6" Padding="10,8"
                BorderBrush="{StaticResource WarningBrush}" BorderThickness="1"
                Visibility="{Binding Monitor.HardwareAvailable, Converter={StaticResource InvertBoolToVisibility}}">
            <Border.Background>
                <SolidColorBrush Color="{StaticResource WarningColor}" Opacity="0.10"/>
            </Border.Background>
            <TextBlock Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap">
                <Run FontWeight="Bold" Text="Hardware-Sensoren nicht verfügbar."/>
                <Run Text=" LibreHardwareMonitor konnte nicht initialisiert werden — nur CPU-Auslastung via Fallback."/>
            </TextBlock>
        </Border>

        <!-- ═══════════════════════════════════════ Hero RAM ════════════════════════════════════ -->
        <Border Grid.Row="2" Style="{StaticResource SensorCard}" Margin="20,0,20,16" Padding="24,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Label + Big Value -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="RAM NUTZUNG" FontSize="10.5" FontWeight="SemiBold"
                               Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="52" FontWeight="SemiBold"
                                   Foreground="{Binding SystemMemory.UsagePercent, Converter={StaticResource PercentToColor}}"
                                   Text="{Binding SystemMemory.UsedPhysical, Converter={StaticResource BytesToGb}}"/>
                        <TextBlock FontSize="22" FontWeight="Normal" VerticalAlignment="Bottom"
                                   Margin="6,0,0,6"
                                   Foreground="{StaticResource TextTertiaryBrush}">
                            <Run Text="/ "/>
                            <Run Text="{Binding SystemMemory.TotalPhysical, Converter={StaticResource BytesToGb}, Mode=OneWay}"/>
                            <Run Text=" GB"/>
                        </TextBlock>
                    </StackPanel>
                    <TextBlock Margin="0,10,0,0" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}">
                        <Run Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Medium"
                             Text="{Binding SystemMemory.UsagePercent, StringFormat={}{0:F1}%}"/>
                        <Run Text=" · "/>
                        <Run Text="{Binding Monitor.TopProcessName, StringFormat=Top: {0}}"/>
                    </TextBlock>
                </StackPanel>

                <!-- Center: Sparkline Chart -->
                <Grid x:Name="RamChart" Grid.Column="1" Margin="24,0,24,0" Height="110">
                    <Polyline Stroke="{Binding SystemMemory.UsagePercent, Converter={StaticResource PercentToColor}}"
                              StrokeThickness="2" Stretch="None"
                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                        <Polyline.Points>
                            <MultiBinding Converter="{StaticResource Sparkline}" ConverterParameter="100">
                                <Binding Path="Monitor.RamPctHistory"/>
                                <Binding ElementName="RamChart" Path="ActualWidth"/>
                                <Binding ElementName="RamChart" Path="ActualHeight"/>
                            </MultiBinding>
                        </Polyline.Points>
                    </Polyline>
                </Grid>

                <!-- Right: 2x2 Mini-Stats -->
                <Grid Grid.Column="2" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,16,12">
                        <TextBlock Text="VERFÜGBAR" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,4"/>
                        <TextBlock FontSize="16" FontWeight="Medium">
                            <Run Foreground="{StaticResource LoadOkBrush}"
                                 Text="{Binding SystemMemory.AvailablePhysical, Converter={StaticResource BytesToGb}}"/>
                            <Run Foreground="{StaticResource TextTertiaryBrush}" FontSize="12" Text=" GB"/>
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="CACHE" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,4"/>
                        <TextBlock FontSize="16" FontWeight="Medium">
                            <Run Foreground="{StaticResource InfoBrush}"
                                 Text="{Binding SystemMemory.CachedBytes, Converter={StaticResource BytesToGb}}"/>
                            <Run Foreground="{StaticResource TextTertiaryBrush}" FontSize="12" Text=" GB"/>
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,16,0">
                        <TextBlock Text="COMMIT" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,4"/>
                        <TextBlock FontSize="16" FontWeight="Medium">
                            <Run Foreground="{StaticResource TextPrimaryBrush}"
                                 Text="{Binding SystemMemory.CommitBytes, Converter={StaticResource BytesToGb}}"/>
                            <Run Foreground="{StaticResource TextTertiaryBrush}" FontSize="12" Text=" GB"/>
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Grid.Row="1">
                        <TextBlock Text="PAGEFILE" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,4"/>
                        <TextBlock FontSize="16" FontWeight="Medium">
                            <Run Foreground="{StaticResource TextPrimaryBrush}"
                                 Text="{Binding SystemMemory.PageFileBytes, Converter={StaticResource BytesToGb}}"/>
                            <Run Foreground="{StaticResource TextTertiaryBrush}" FontSize="12" Text=" GB"/>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════ 4-Card Grid ═════════════════════════════════ -->
        <Grid Grid.Row="3" Margin="20,0,20,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- CPU Card -->
            <Border Grid.Column="0" Style="{StaticResource SensorCard}">
                <StackPanel>
                    <!-- Head -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Path Width="16" Height="16" Stretch="Uniform" StrokeThickness="1.3"
                              Stroke="{StaticResource TextSecondaryBrush}"
                              Data="M 3 3 L 13 3 L 13 13 L 3 13 Z M 5.5 5.5 L 10.5 5.5 L 10.5 10.5 L 5.5 10.5 Z
                                    M 6 1.5 L 6 3 M 10 1.5 L 10 3 M 6 13 L 6 14.5 M 10 13 L 10 14.5
                                    M 1.5 6 L 3 6 M 1.5 10 L 3 10 M 13 6 L 14.5 6 M 13 10 L 14.5 10"/>
                        <TextBlock Text="CPU" FontSize="11" FontWeight="SemiBold" Margin="8,0,0,0"
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Monitor.Cores.Count, StringFormat={}{0} Kerne}"
                                   FontSize="10.5" Margin="0,0,0,0" HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextTertiaryBrush}"/>
                    </StackPanel>

                    <!-- Value -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock FontSize="30" FontWeight="SemiBold"
                                   Foreground="{Binding Monitor.CpuUsage, Converter={StaticResource PercentToColor}}"
                                   Text="{Binding Monitor.CpuUsage, StringFormat={}{0:F1}%, TargetNullValue='—'}"/>
                        <TextBlock FontSize="11" VerticalAlignment="Bottom" Margin="8,0,0,6"
                                   Foreground="{StaticResource TextTertiaryBrush}">
                            <Run Text="∅ "/>
                            <Run Text="{Binding Monitor.CpuAvg, StringFormat={}{0:F1}%, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>

                    <!-- Meta -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                            <Run Text="Temp "/>
                            <Run Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Medium"
                                 Text="{Binding Monitor.CpuTemp, StringFormat={}{0:F0}, TargetNullValue='—'}"/>
                            <Run Text=" °C"/>
                        </TextBlock>
                        <TextBlock FontSize="12" Margin="14,0,0,0" Foreground="{StaticResource TextSecondaryBrush}">
                            <Run Text="Takt "/>
                            <Run Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Medium"
                                 Text="{Binding Monitor.CpuFreqMHz, StringFormat={}{0:F0}, TargetNullValue='—'}"/>
                            <Run Text=" MHz"/>
                        </TextBlock>
                    </StackPanel>

                    <!-- Chart -->
                    <Grid x:Name="CpuChart" Height="62" Margin="0,4,0,4">
                        <Polyline Stroke="{Binding Monitor.CpuUsage, Converter={StaticResource PercentToColor}}"
                                  StrokeThickness="1.7" Stretch="None"
                                  StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                            <Polyline.Points>
                                <MultiBinding Converter="{StaticResource Sparkline}" ConverterParameter="100">
                                    <Binding Path="Monitor.CpuHistory"/>
                                    <Binding ElementName="CpuChart" Path="ActualWidth"/>
                                    <Binding ElementName="CpuChart" Path="ActualHeight"/>
                                </MultiBinding>
                            </Polyline.Points>
                        </Polyline>
                    </Grid>

                    <!-- Footer -->
                    <Grid>
                        <TextBlock Text="60 s" FontSize="10.5" Foreground="{StaticResource TextTertiaryBrush}"
                                   HorizontalAlignment="Left"/>
                        <TextBlock Text="100%" FontSize="10.5" Foreground="{StaticResource TextTertiaryBrush}"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- GPU Card -->
            <Border Grid.Column="2" Style="{StaticResource SensorCard}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Path Width="16" Height="16" Stretch="Uniform" StrokeThickness="1.3"
                              Stroke="{StaticResource TextSecondaryBrush}"
                              Data="M 2 5 L 14 5 L 14 12 L 2 12 Z
                                    M 6 8.5 A 1.3 1.3 0 1 0 6 8.499 Z
                                    M 10 8.5 A 1.3 1.3 0 1 0 10 8.499 Z
                                    M 4 12 L 4 14 M 12 12 L 12 14"/>
                        <TextBlock Text="GPU" FontSize="11" FontWeight="SemiBold" Margin="8,0,0,0"
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock FontSize="10.5" HorizontalAlignment="Right" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextTertiaryBrush}">
                            <Run Text="{Binding Monitor.GpuClockMHz, StringFormat={}{0:F0}, TargetNullValue='—'}"/>
                            <Run Text=" MHz"/>
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock FontSize="30" FontWeight="SemiBold"
                                   Foreground="{Binding Monitor.GpuUsage, Converter={StaticResource PercentToColor}}"
                                   Text="{Binding Monitor.GpuUsage, StringFormat={}{0:F1}%, TargetNullValue='—'}"/>
                        <TextBlock FontSize="11" VerticalAlignment="Bottom" Margin="8,0,0,6"
                                   Foreground="{StaticResource TextTertiaryBrush}">
                            <Run Text="{Binding Monitor.GpuVramUsedGb, StringFormat={}{0:F1}, TargetNullValue='—'}"/>
                            <Run Text=" / "/>
                            <Run Text="{Binding Monitor.GpuVramTotalGb, StringFormat={}{0:F1} GB, TargetNullValue='— GB'}"/>
                            <Run Text=" VRAM"/>
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                            <Run Text="Temp "/>
                            <Run Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Medium"
                                 Text="{Binding Monitor.GpuTemp, StringFormat={}{0:F0}, TargetNullValue='—'}"/>
                            <Run Text=" °C"/>
                        </TextBlock>
                        <TextBlock FontSize="12" Margin="14,0,0,0" Foreground="{StaticResource TextSecondaryBrush}">
                            <Run Text="∅ "/>
                            <Run Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Medium"
                                 Text="{Binding Monitor.GpuAvg, StringFormat={}{0:F1}%, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>

                    <Grid x:Name="GpuChart" Height="62" Margin="0,4,0,4">
                        <Polyline Stroke="{Binding Monitor.GpuUsage, Converter={StaticResource PercentToColor}}"
                                  StrokeThickness="1.7" Stretch="None"
                                  StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                            <Polyline.Points>
                                <MultiBinding Converter="{StaticResource Sparkline}" ConverterParameter="100">
                                    <Binding Path="Monitor.GpuHistory"/>
                                    <Binding ElementName="GpuChart" Path="ActualWidth"/>
                                    <Binding ElementName="GpuChart" Path="ActualHeight"/>
                                </MultiBinding>
                            </Polyline.Points>
                        </Polyline>
                    </Grid>

                    <Grid>
                        <TextBlock Text="60 s" FontSize="10.5" Foreground="{StaticResource TextTertiaryBrush}"
                                   HorizontalAlignment="Left"/>
                        <TextBlock Text="100%" FontSize="10.5" Foreground="{StaticResource TextTertiaryBrush}"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Disk Card -->
            <Border Grid.Column="4" Style="{StaticResource SensorCard}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Path Width="16" Height="16" Stretch="Uniform" StrokeThickness="1.3"
                              Stroke="{StaticResource TextSecondaryBrush}"
                              Data="M 3 4 A 5 1.6 0 1 0 13 4 A 5 1.6 0 1 0 3 4 Z
                                    M 3 4 L 3 12 M 13 4 L 13 12
                                    M 3 12 A 5 1.6 0 0 0 13 12
                                    M 3 8 A 5 1.6 0 0 0 13 8"/>
                        <TextBlock Text="DISK" FontSize="11" FontWeight="SemiBold" Margin="8,0,0,0"
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="NVMe" FontSize="10.5" HorizontalAlignment="Right" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextTertiaryBrush}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock FontSize="26" FontWeight="SemiBold" Foreground="{StaticResource LoadOkBrush}">
                            <Run Text="↓ "/>
                            <Run Text="{Binding Monitor.DiskReadMBps, StringFormat={}{0:F1}, TargetNullValue='—'}"/>
                        </TextBlock>
                        <TextBlock FontSize="11" VerticalAlignment="Bottom" Margin="8,0,0,4"
                                   Foreground="{StaticResource TextTertiaryBrush}" Text="MB/s"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock FontSize="12" Foreground="{StaticResource LoadWarnBrush}">
                            <Run Text="↑ "/>
                            <Run FontWeight="Medium"
                                 Text="{Binding Monitor.DiskWriteMBps, StringFormat={}{0:F1}, TargetNullValue='—'}"/>
                            <Run Text=" MB/s"/>
                        </TextBlock>
                        <TextBlock FontSize="12" Margin="14,0,0,0" Foreground="{StaticResource TextSecondaryBrush}">
                            <Run Text="Temp "/>
                            <Run Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Medium"
                                 Text="{Binding Monitor.DiskTemp, StringFormat={}{0:F0}, TargetNullValue='—'}"/>
                            <Run Text=" °C"/>
                        </TextBlock>
                    </StackPanel>

                    <Grid x:Name="DiskChart" Height="62" Margin="0,4,0,4">
                        <Polyline Stroke="{StaticResource LoadWarnBrush}"
                                  StrokeThickness="1.3" StrokeDashArray="3 2" Opacity="0.85"
                                  Stretch="None" StrokeLineJoin="Round">
                            <Polyline.Points>
                                <MultiBinding Converter="{StaticResource Sparkline}" ConverterParameter="100">
                                    <Binding Path="Monitor.DiskWriteHistory"/>
                                    <Binding ElementName="DiskChart" Path="ActualWidth"/>
                                    <Binding ElementName="DiskChart" Path="ActualHeight"/>
                                </MultiBinding>
                            </Polyline.Points>
                        </Polyline>
                        <Polyline Stroke="{StaticResource LoadOkBrush}"
                                  StrokeThickness="1.7" Stretch="None"
                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                            <Polyline.Points>
                                <MultiBinding Converter="{StaticResource Sparkline}" ConverterParameter="100">
                                    <Binding Path="Monitor.DiskReadHistory"/>
                                    <Binding ElementName="DiskChart" Path="ActualWidth"/>
                                    <Binding ElementName="DiskChart" Path="ActualHeight"/>
                                </MultiBinding>
                            </Polyline.Points>
                        </Polyline>
                    </Grid>

                    <Grid>
                        <TextBlock Text="60 s" FontSize="10.5" Foreground="{StaticResource TextTertiaryBrush}"
                                   HorizontalAlignment="Left"/>
                        <TextBlock FontSize="10.5" Foreground="{StaticResource TextTertiaryBrush}"
                                   HorizontalAlignment="Right">
                            <Run Text="{Binding Monitor.DiskScaleMax, StringFormat={}{0:F0}, Mode=OneWay}"/>
                            <Run Text=" MB/s"/>
                        </TextBlock>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Netzwerk Card -->
            <Border Grid.Column="6" Style="{StaticResource SensorCard}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Path Width="16" Height="16" Stretch="Uniform" StrokeThickness="1.3"
                              Stroke="{StaticResource TextSecondaryBrush}"
                              Data="M 1 8 A 10 10 0 0 1 15 8
                                    M 3.5 10.5 A 6 6 0 0 1 12.5 10.5
                                    M 6 13 A 2.5 2.5 0 0 1 10 13"/>
                        <TextBlock Text="NETZWERK" FontSize="11" FontWeight="SemiBold" Margin="8,0,0,0"
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Live" FontSize="10.5" HorizontalAlignment="Right" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextTertiaryBrush}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock FontSize="26" FontWeight="SemiBold" Foreground="{StaticResource LoadOkBrush}">
                            <Run Text="↓ "/>
                            <Run Text="{Binding Monitor.NetDownMbitps, StringFormat={}{0:F1}, TargetNullValue='—'}"/>
                        </TextBlock>
                        <TextBlock FontSize="11" VerticalAlignment="Bottom" Margin="8,0,0,4"
                                   Foreground="{StaticResource TextTertiaryBrush}" Text="Mbit/s"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock FontSize="12" Foreground="{StaticResource LoadWarnBrush}">
                            <Run Text="↑ "/>
                            <Run FontWeight="Medium"
                                 Text="{Binding Monitor.NetUpMbitps, StringFormat={}{0:F1}, TargetNullValue='—'}"/>
                            <Run Text=" Mbit/s"/>
                        </TextBlock>
                    </StackPanel>

                    <Grid x:Name="NetChart" Height="62" Margin="0,4,0,4">
                        <Polyline Stroke="{StaticResource LoadWarnBrush}"
                                  StrokeThickness="1.3" StrokeDashArray="3 2" Opacity="0.85"
                                  Stretch="None" StrokeLineJoin="Round">
                            <Polyline.Points>
                                <MultiBinding Converter="{StaticResource Sparkline}" ConverterParameter="100">
                                    <Binding Path="Monitor.NetUpHistory"/>
                                    <Binding ElementName="NetChart" Path="ActualWidth"/>
                                    <Binding ElementName="NetChart" Path="ActualHeight"/>
                                </MultiBinding>
                            </Polyline.Points>
                        </Polyline>
                        <Polyline Stroke="{StaticResource LoadOkBrush}"
                                  StrokeThickness="1.7" Stretch="None"
                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                            <Polyline.Points>
                                <MultiBinding Converter="{StaticResource Sparkline}" ConverterParameter="100">
                                    <Binding Path="Monitor.NetDownHistory"/>
                                    <Binding ElementName="NetChart" Path="ActualWidth"/>
                                    <Binding ElementName="NetChart" Path="ActualHeight"/>
                                </MultiBinding>
                            </Polyline.Points>
                        </Polyline>
                    </Grid>

                    <Grid>
                        <TextBlock Text="60 s" FontSize="10.5" Foreground="{StaticResource TextTertiaryBrush}"
                                   HorizontalAlignment="Left"/>
                        <TextBlock FontSize="10.5" Foreground="{StaticResource TextTertiaryBrush}"
                                   HorizontalAlignment="Right">
                            <Run Text="{Binding Monitor.NetScaleMax, StringFormat={}{0:F0}, Mode=OneWay}"/>
                            <Run Text=" Mbit/s"/>
                        </TextBlock>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════ Ticker ═══════════════════════════════════════ -->
        <Border Grid.Row="4" Style="{StaticResource CardBorder}" Margin="20,0,20,20" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="6" Height="6" Fill="{StaticResource LoadOkBrush}" Margin="0,0,10,0"/>
                    <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                        <Run Text="System "/>
                        <Run Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Medium" Text="stabil"/>
                    </TextBlock>
                    <TextBlock FontSize="12" Margin="12,0,0,0" Foreground="{StaticResource TextDisabledBrush}" Text="·"/>
                    <TextBlock FontSize="12" Margin="12,0,0,0" Foreground="{StaticResource TextSecondaryBrush}">
                        <Run Text="Uptime "/>
                        <Run Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Medium"
                             Text="{Binding Monitor.UptimeText}"/>
                    </TextBlock>
                    <TextBlock FontSize="12" Margin="12,0,0,0" Foreground="{StaticResource TextDisabledBrush}" Text="·"/>
                    <TextBlock FontSize="12" Margin="12,0,0,0" Foreground="{StaticResource TextSecondaryBrush}">
                        <Run Text="Top "/>
                        <Run Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Medium"
                             Text="{Binding Monitor.TopProcessName}"/>
                        <Run Text=" · "/>
                        <Run Text="{Binding Monitor.TopProcessSize}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                        <Run Text="∅ CPU "/>
                        <Run Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Medium"
                             Text="{Binding Monitor.CpuAvg, StringFormat={}{0:F1}%, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock FontSize="12" Margin="12,0,0,0" Foreground="{StaticResource TextDisabledBrush}" Text="·"/>
                    <TextBlock FontSize="12" Margin="12,0,0,0" Foreground="{StaticResource TextSecondaryBrush}">
                        <Run Text="∅ GPU "/>
                        <Run Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Medium"
                             Text="{Binding Monitor.GpuAvg, StringFormat={}{0:F1}%, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
    </ScrollViewer>
</UserControl>
